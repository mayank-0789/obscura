{
  "name": "payrail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @payrail/db exec drizzle-kit generate",
    "db:push": "pnpm --filter @payrail/db exec drizzle-kit push",
    "db:studio": "pnpm --filter @payrail/db exec drizzle-kit studio",
    "db:migrate": "pnpm --filter @payrail/db exec drizzle-kit migrate",
    "spike:privy": "tsx scripts/privy-spike.ts"
  },
  "devDependencies": {
    "@privy-io/server-auth": "^1.32.5",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  }
}
