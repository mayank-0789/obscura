{
  "name": "payrail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @payrail/db exec drizzle-kit generate",
    "db:push": "pnpm --filter @payrail/db exec drizzle-kit push",
    "db:studio": "pnpm --filter @payrail/db exec drizzle-kit studio",
    "db:migrate": "pnpm --filter @payrail/db exec drizzle-kit migrate",
    "spike:privy": "tsx scripts/privy-spike.ts",
    "spike:privy-variants": "tsx scripts/spike-privy-variants.ts",
    "spike:x402-sign": "tsx scripts/spike-x402-sign.ts",
    "stage1:setup": "tsx scripts/stage1-setup.ts",
    "stage1:fund": "tsx scripts/stage1-fund.ts",
    "stage1:merchant": "tsx scripts/stage1-merchant.ts",
    "stage1:client": "tsx scripts/stage1-client.ts",
    "stage2:client": "tsx scripts/stage2-client.ts",
    "stage2:provision-agent": "tsx scripts/stage2-provision-agent.ts"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@payrail/merchant-sdk": "workspace:*",
    "@payrail/sdk": "workspace:*",
    "@privy-io/server-auth": "^1.32.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "nanoid": "^5.1.9",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "x402-solana": "^2.0.4"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  }
}
