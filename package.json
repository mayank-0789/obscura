{
  "name": "payrail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @payrail-app/db exec drizzle-kit generate",
    "db:push": "pnpm --filter @payrail-app/db exec drizzle-kit push",
    "db:studio": "pnpm --filter @payrail-app/db exec drizzle-kit studio",
    "db:migrate": "pnpm --filter @payrail-app/db exec drizzle-kit migrate",
    "umbra:bootstrap-treasury": "tsx scripts/umbra-bootstrap-treasury.ts",
    "umbra:wrap-treasury-sol": "tsx scripts/umbra-wrap-treasury-sol.ts",
    "umbra:test-mixer-send": "tsx scripts/umbra-test-mixer-send.ts",
    "umbra:claim-daemon": "tsx scripts/umbra-claim-daemon.ts",
    "umbra:reconcile-pending": "tsx scripts/umbra-reconcile-pending.ts"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@payrail-app/merchant-sdk": "workspace:*",
    "@payrail-app/sdk": "workspace:*",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "nanoid": "^5.1.9",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "x402-solana": "^2.0.4"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@umbra-privacy/web-zk-prover>@umbra-privacy/sdk": "4.0.0"
      }
    }
  }
}
