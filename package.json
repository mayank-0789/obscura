{
  "name": "payrail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @obscura-app/db exec drizzle-kit generate",
    "db:push": "pnpm --filter @obscura-app/db exec drizzle-kit push",
    "db:studio": "pnpm --filter @obscura-app/db exec drizzle-kit studio",
    "db:migrate": "pnpm --filter @obscura-app/db exec drizzle-kit migrate",
    "dev:demo": "concurrently --names web,merchant --prefix-colors cyan,magenta --kill-others-on-fail \"pnpm --filter web dev\" \"pnpm --filter demo-merchant-news dev\"",
    "umbra:bootstrap-treasury": "tsx scripts/umbra-bootstrap-treasury.ts",
    "umbra:wrap-treasury-sol": "tsx scripts/umbra-wrap-treasury-sol.ts",
    "umbra:claim-daemon": "tsx scripts/umbra-claim-daemon.ts",
    "umbra:reconcile-pending": "tsx scripts/umbra-reconcile-pending.ts",
    "umbra:bootstrap-merchant": "tsx scripts/umbra-bootstrap-merchant.ts"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@umbra-privacy/web-zk-prover>@umbra-privacy/sdk": "4.0.0"
      }
    }
  }
}
