# =============================================================================
# Obscura — environment variables
# =============================================================================
# Copy to `.env` at the monorepo root and fill in real values. `.env` is
# git-ignored. Production values live in Railway's per-service Variables panel.
#
# Each var is tagged:
#   [web]      = needed by the Next.js app (apps/web)
#   [merchant] = needed by the demo-merchant Express server (apps/demo-merchant-news)
#   [cron]     = needed by the cron containers (Railway cron jobs)
#   *required  = app crashes at boot without it
#   *optional  = graceful degrade
# =============================================================================


# -----------------------------------------------------------------------------
# App URL + cluster — [web] *required (NEXT_PUBLIC_*  is bundled at build time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"


# -----------------------------------------------------------------------------
# Database — [web] *required
# -----------------------------------------------------------------------------
# Neon serverless Postgres. Pooler endpoint with `?sslmode=require`.
DATABASE_URL=""


# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5) — [web] *required
# -----------------------------------------------------------------------------
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""

# Optional in dev (inferred from request). Set explicitly in prod to pin
# the canonical URL behind Railway's proxy.
# AUTH_URL="https://obscurapp.com"

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URIs MUST include both:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://obscurapp.com/api/auth/callback/google   (prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""


# -----------------------------------------------------------------------------
# Solana RPC + treasury + asset — [web, merchant] *required
# -----------------------------------------------------------------------------
# Helius devnet RPC URL with ?api-key=...
HELIUS_RPC_URL=""

# Treasury keypair — funds new ETA registrations + signs direct deposits.
# TREASURY_SECRET_KEY: 64-byte JSON array from `solana-keygen` ([12,34,...,89]).
# TREASURY_PUBLIC_KEY: base58 pubkey. Both required by [web].
TREASURY_SECRET_KEY=""
TREASURY_PUBLIC_KEY=""

# Asset moved by deposits/spends. Must match across [web] and [merchant].
#   Devnet: WSOL (decimals=9) — Umbra devnet only supports WSOL.
#   Mainnet: USDC (decimals=6).
STABLECOIN_MINT="So11111111111111111111111111111111111111112"
STABLECOIN_DECIMALS="9"


# -----------------------------------------------------------------------------
# Umbra Privacy — [web] *required (seed) + *optional (URLs)
# -----------------------------------------------------------------------------
# Master HMAC seed. Every agent + merchant keypair is derived from this via
# HMAC(seed, "umbra/v1/<subject>-signing-key|<id>"). ≥32 chars.
# Generate: openssl rand -hex 32
# CRITICAL: lose this and every encrypted balance becomes unrecoverable.
UMBRA_AGENT_SEED_SECRET=""

# Defaults to "devnet". Set "mainnet" only after the mainnet flip is ready.
UMBRA_NETWORK="devnet"

# Override only if your WS endpoint differs from HELIUS_RPC_URL's host.
# UMBRA_RPC_SUBSCRIPTIONS_URL=""

# Hosted indexer + relayer (request URLs from Umbra Discord). Required for the
# mixer claim daemon — it 503s without these. Direct deposit/withdraw paths
# still work without them.
UMBRA_INDEXER_URL=""
UMBRA_RELAYER_URL=""


# -----------------------------------------------------------------------------
# Helius enhanced webhooks — [web] *optional
# -----------------------------------------------------------------------------
# When all three are set, merchant payout addresses auto-register to a
# shared Helius webhook for realtime SSE updates. Webhook URL in the Helius
# dashboard must point at:
#   https://obscurapp.com/api/webhooks/helius
# Without these, merchant dashboards fall back to polling.
HELIUS_API_KEY=""
HELIUS_WEBHOOK_ID=""
HELIUS_WEBHOOK_AUTH_TOKEN=""


# -----------------------------------------------------------------------------
# Cron + admin — [web, cron] *required for cron functionality
# -----------------------------------------------------------------------------
# Bearer token for /api/cron/*. MUST be the same value on the [web] service
# and on each cron container. ≥16 chars. Generate: openssl rand -base64 32
CRON_SECRET=""

# Bearer token for /api/admin/* (e.g. helius/reconcile). ≥32 chars.
ADMIN_API_TOKEN=""


# -----------------------------------------------------------------------------
# Demo (judge-facing /demo button) — [web] *optional
# -----------------------------------------------------------------------------
# Both must be set or /api/demo/run returns 503.
#   DEMO_AGENT_API_KEY: a pk_... key from a funded agent in this DB.
#   DEMO_MERCHANT_URL:  public URL of the deployed demo-merchant service
#                       (Railway: https://<svc>.up.railway.app).
DEMO_AGENT_API_KEY=""
DEMO_MERCHANT_URL=""


# -----------------------------------------------------------------------------
# Dodo Payments (fiat on-ramp) — [web] *required for top-ups
# -----------------------------------------------------------------------------
# Dashboard → Developer → API keys.
DODO_PAYMENTS_API_KEY=""

# Dashboard → Webhooks. Webhook URL MUST be:
#   https://obscurapp.com/api/webhooks/dodo
# Subscribe only to: payment.succeeded, payment.failed, refund.succeeded,
# dispute.opened. The whsec_... below is bound to that specific webhook.
DODO_WEBHOOK_KEY=""

# Dashboard → Products → Obscura Top-up → product ID.
DODO_TOPUP_PRODUCT_ID=""

# test_mode for devnet/dev; live_mode only after mainnet flip + tax category fix.
DODO_ENVIRONMENT="test_mode"


# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting) — [web] *optional
# -----------------------------------------------------------------------------
# When unset, rate limiters allow-all. Set in prod.
#   console.upstash.com → Create database → copy REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# =============================================================================
# Demo merchant service (apps/demo-merchant-news) — set only on that service
# =============================================================================
# These belong on the demo-merchant Railway service's Variables panel, NOT on
# the [web] service. They're listed here for reference / local dev where one
# .env serves both processes via `pnpm dev:demo`.

# *required — the merchant's ETA address. Must be a row in the merchants
# table (web's DB) so the claim daemon will scan + claim its UTXOs.
# Look up: SELECT eta_address FROM merchants WHERE name = '<your merchant>';
MERCHANT_ETA_ADDRESS=""

# Same STABLECOIN_MINT + STABLECOIN_DECIMALS + HELIUS_RPC_URL as [web].
# Listed in the [web] section above; reuse those values. Critical that they
# match — the merchant SDK rejects payments whose envelope asset doesn't match.

# Railway sets PORT automatically; only override locally if 3001 is busy.
# PORT="3001"
