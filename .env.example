# ============================================================================
# Payrail — environment variables (template)
# Copy to `.env` (monorepo root) and fill in real values. `.env` is git-ignored.
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Database (Neon serverless Postgres) ----
DATABASE_URL=""

# ---- Privy (auth + embedded wallets) ----
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
NEXT_PUBLIC_PRIVY_APP_ID=""

# Authorization key for delegated server-side signing.
# Generate in Privy dashboard → Wallets → Authorization Keys (or Key Quorums).
# PRIVY_AUTHORIZATION_KEY    — the private half (secret, shown once at creation).
# PRIVY_AUTHORIZATION_KEY_ID — the key's ID, attached to every agent wallet.
PRIVY_AUTHORIZATION_KEY=""
PRIVY_AUTHORIZATION_KEY_ID=""

# ---- Solana ----
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# Helius RPC — devnet URL from helius.dev → project → copy.
HELIUS_RPC_URL=""

# Treasury wallet — raw keypair that signs treasury → agent transfers.
# TREASURY_SECRET_KEY  — the JSON array from `solana-keygen` (e.g. [12,34,...,89]).
#                        Keep as-is, including brackets. 64 bytes.
# TREASURY_PUBLIC_KEY  — the base58 pubkey the keygen printed.
TREASURY_SECRET_KEY=""
TREASURY_PUBLIC_KEY=""

# Stablecoin mint — the SPL token being moved. Swap value to change currency.
# Default below is Circle's devnet USDC. Change STABLECOIN_DECIMALS alongside
# if onboarding a token with non-6-decimal precision.
STABLECOIN_MINT="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"
STABLECOIN_DECIMALS="6"

# ---- Dodo Payments (fiat on-ramp) ----
# Dashboard → Developer → API keys (test_mode / live_mode).
DODO_PAYMENTS_API_KEY=""
# Dashboard → Developer → Webhooks → signing secret (starts with whsec_).
DODO_WEBHOOK_KEY=""
# Dashboard → Products → Payrail Top-up (Pay What You Want) → product ID.
DODO_TOPUP_PRODUCT_ID=""
# test_mode for devnet work; live_mode for production.
DODO_ENVIRONMENT="test_mode"

# ---- Upstash Redis (rate limiting) ----
# Optional locally — when unset, rate limiters allow all traffic.
# Set in prod: https://console.upstash.com/ → Create database → copy REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

