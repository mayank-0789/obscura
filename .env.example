# ============================================================================
# Payrail — environment variables (template)
# Copy to `.env` (monorepo root) and fill in real values. `.env` is git-ignored.
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Database (Neon serverless Postgres) ----
DATABASE_URL=""

# ---- Privy (auth + embedded wallets) ----
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
NEXT_PUBLIC_PRIVY_APP_ID=""

# Authorization key for delegated server-side signing.
# Generate in Privy dashboard → Wallets → Authorization Keys (or Key Quorums).
# PRIVY_AUTHORIZATION_KEY    — the private half (secret, shown once at creation).
# PRIVY_AUTHORIZATION_KEY_ID — the key's ID, attached to every agent wallet.
PRIVY_AUTHORIZATION_KEY=""
PRIVY_AUTHORIZATION_KEY_ID=""

# ---- Solana ----
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# ---- Upstash Redis (rate limiting) ----
# Optional locally — when unset, rate limiters allow all traffic.
# Set in prod: https://console.upstash.com/ → Create database → copy REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================================
# More env vars will be added as features ship:
#   • Dodo Payments (fiat checkout)       — Day 5
#   • Helius (Solana RPC)                  — Day 2
#   • Treasury signer key + USDG mint      — Day 2
#   • Upstash Redis (rate limiting)        — Week 2
#   • Inngest (background jobs)            — Day 6
#   • Resend (email)                       — Week 3
# ============================================================================
