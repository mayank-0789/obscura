# ============================================================================
# Payrail — environment variables (template)
# Copy to `.env` (monorepo root) and fill in real values. `.env` is git-ignored.
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Database (Neon serverless Postgres) ----
DATABASE_URL=""

# ---- Auth.js (NextAuth v5) ----
# AUTH_SECRET signs the session cookie + JWT. Generate: openssl rand -base64 32
AUTH_SECRET=""
# Optional in dev (Auth.js infers from request); set explicitly in prod.
# AUTH_URL="http://localhost:3000"

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Solana ----
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# Helius RPC — devnet URL from helius.dev → project → copy.
HELIUS_RPC_URL=""

# Treasury wallet — raw keypair that signs treasury → agent transfers.
# TREASURY_SECRET_KEY  — the JSON array from `solana-keygen` (e.g. [12,34,...,89]).
#                        Keep as-is, including brackets. 64 bytes.
# TREASURY_PUBLIC_KEY  — the base58 pubkey the keygen printed.
TREASURY_SECRET_KEY=""
TREASURY_PUBLIC_KEY=""

# Stablecoin mint — the SPL token being moved. Swap value to change currency.
# Devnet today: WSOL (Umbra devnet limitation). Mainnet: real USDC.
STABLECOIN_MINT="So11111111111111111111111111111111111111112"
STABLECOIN_DECIMALS="9"

# ---- Umbra Privacy SDK ----
# Server-derived seed material — every agent + merchant Umbra keypair is
# derived via HMAC(this, identity). MUST be ≥32 chars. Generate:
#   openssl rand -hex 32
# Lose this and all encrypted balances become unrecoverable. Treat as critical.
UMBRA_AGENT_SEED_SECRET=""
# Network: devnet (hackathon) | mainnet | localnet
UMBRA_NETWORK="devnet"
# Override only if the WS endpoint diverges from HELIUS_RPC_URL.
# UMBRA_RPC_SUBSCRIPTIONS_URL=""

# ---- Dodo Payments (fiat on-ramp) ----
# Dashboard → Developer → API keys (test_mode / live_mode).
DODO_PAYMENTS_API_KEY=""
# Dashboard → Developer → Webhooks → signing secret (starts with whsec_).
DODO_WEBHOOK_KEY=""
# Dashboard → Products → Payrail Top-up (Pay What You Want) → product ID.
DODO_TOPUP_PRODUCT_ID=""
# test_mode for devnet work; live_mode for production.
DODO_ENVIRONMENT="test_mode"

# ---- Upstash Redis (rate limiting) ----
# Optional locally — when unset, rate limiters allow all traffic.
# Set in prod: https://console.upstash.com/ → Create database → copy REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
