{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "VERCEL_ENV", "SKIP_ENV_VALIDATION"],
  "globalPassThroughEnv": ["PATH", "HOME"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_URL",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "DODO_PAYMENTS_API_KEY",
        "DODO_WEBHOOK_KEY",
        "DODO_TOPUP_PRODUCT_ID",
        "DODO_ENVIRONMENT",
        "HELIUS_RPC_URL",
        "HELIUS_API_KEY",
        "HELIUS_WEBHOOK_ID",
        "HELIUS_WEBHOOK_AUTH_TOKEN",
        "TREASURY_SECRET_KEY",
        "TREASURY_PUBLIC_KEY",
        "STABLECOIN_MINT",
        "STABLECOIN_DECIMALS",
        "ADMIN_API_TOKEN",
        "UMBRA_AGENT_SEED_SECRET",
        "UMBRA_NETWORK",
        "UMBRA_RPC_SUBSCRIPTIONS_URL",
        "UMBRA_INDEXER_URL",
        "UMBRA_RELAYER_URL",
        "CRON_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_SOLANA_CLUSTER"
      ]
    },
    "lint": { "dependsOn": ["^lint"] },
    "check-types": { "dependsOn": ["^check-types"] },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
