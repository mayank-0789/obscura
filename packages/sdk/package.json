{
  "name": "@payrail/sdk",
  "version": "0.1.0",
  "description": "Pay-per-call SDK for AI agents — wraps fetch() to handle x402 payments via Payrail on Solana.",
  "license": "MIT",
  "author": "Payrail",
  "homepage": "https://payrail.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/payrail/payrail.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "x402",
    "solana",
    "ai-agents",
    "stablecoin",
    "payments",
    "usdc",
    "usdg",
    "payrail"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
