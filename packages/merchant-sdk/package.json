{
  "name": "@obscura-app/merchant-sdk",
  "version": "0.1.2",
  "description": "Express middleware for API sellers to accept confidential x402 payments on Solana via the Umbra mixer.",
  "license": "MIT",
  "author": "Obscura",
  "homepage": "https://github.com/mayank-0789/obscura",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayank-0789/obscura.git",
    "directory": "packages/merchant-sdk"
  },
  "keywords": [
    "x402",
    "solana",
    "express",
    "middleware",
    "payments",
    "api-monetization",
    "usdc",
    "obscura"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "@solana/web3.js": ">=1.98.4"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.15.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
